Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Display", " ", "a", " ", "map", " ", "showing", " ", "the", " ", 
    "location", " ", "of", " ", "the", " ", "weather", " ", "station"}], 
   "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Given", " ", "the", " ", "location", " ", "of", " ", "WMO", " ", 
     "weather", " ", "stations"}], ",", " ", 
    RowBox[{
    "calculate", " ", "radius", " ", "to", " ", "cirumscribe", " ", "50", " ",
      "WMO", " ", 
     RowBox[{"stations", "."}]}]}], "*)"}], "\n", "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{"GeoGraphics", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Red", ",", 
         RowBox[{"Point", "/@", "WMOLocationsMX"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Black", ",", 
         RowBox[{"Point", "[", "ptsMX", "]"}]}], "}"}]}], "}"}], ",", 
     RowBox[{"GeoRange", "\[Rule]", 
      TemplateBox[{"\"Mexico\"",RowBox[{"Entity", "[", 
          RowBox[{"\"Country\"", ",", "\"Mexico\""}], "]"}],
        "\"Entity[\\\"Country\\\", \\\"Mexico\\\"]\"","\"country\""},
       "Entity"]}]}], "]"}], "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{"GeoGraphics", "[", 
    RowBox[{"GeoDisk", "[", 
     RowBox[{
      RowBox[{"ToExpression", "/@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
         RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], "}"}]}], 
      ",", " ", "\n", "\t\t", 
      RowBox[{
       RowBox[{"GeoRange", "\[Rule]", " ", 
        RowBox[{"GeoDistanceList", "[", 
         RowBox[{"GeoNearest", "[", 
          RowBox[{
           RowBox[{"Normal", "[", "WMOLocations", "]"}], ",", " ", "\n", 
           "\t\t", 
           RowBox[{"ToExpression", "/@", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
              RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], 
             "}"}]}], ",", " ", "20"}], "]"}], "]"}]}], "//", "Max"}]}], 
     "]"}], "]"}], "\n", "\t\t", "\n", 
   RowBox[{"GeoListPlot", "[", 
    RowBox[{"GeoNearest", "[", 
     RowBox[{
      RowBox[{"Normal", "[", "WMOLocations", "]"}], ",", " ", 
      RowBox[{"ToExpression", "/@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
         RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], "}"}]}], 
      ",", " ", "20"}], "]"}], "]"}], "\t", "\n", "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Find", " ", "the", " ", "closest", " ", "WMO", " ", "weather", " ", 
     "station", " ", "and", " ", "compare", " ", "the", " ", "data", " ", 
     "from", " ", "your", " ", "weather", " ", 
     RowBox[{"station", ".", " ", "\n", "Take"}], " ", "100", " ", "random", 
     " ", "locations", " ", "across", " ", "the", " ", "US", " ", "and", " ", 
     "calculate", " ", "the", " ", "average", " ", "\"\<proximity value\>\"", 
     " ", "for", " ", "those", " ", "areas"}], "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"loc", "=", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"ToExpression", "/@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
         RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], "}"}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"list", "=", 
    RowBox[{"{", "\n", 
     RowBox[{
      RowBox[{"Mean", "[", 
       RowBox[{"GeoDistance", "[", 
        RowBox[{
         RowBox[{"GeoNearest", "[", 
          RowBox[{
           RowBox[{"Normal", "[", "WMOLocations", "]"}], ",", " ", 
           RowBox[{"ToExpression", "/@", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
              RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], 
             "}"}]}], ",", "1"}], "]"}], ",", " ", "loc"}], "]"}], "]"}], ",",
       "\n", 
      RowBox[{"Mean", "[", 
       RowBox[{"GeoDistanceList", "[", 
        RowBox[{"GeoNearest", "[", 
         RowBox[{
          RowBox[{"Normal", "[", "WMOLocations", "]"}], ",", " ", 
          RowBox[{"ToExpression", "/@", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
             RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], 
            "}"}]}], ",", " ", "10"}], "]"}], "]"}], "]"}], ",", "\n", 
      RowBox[{"Mean", "[", 
       RowBox[{"GeoDistanceList", "[", 
        RowBox[{"GeoNearest", "[", 
         RowBox[{
          RowBox[{"Normal", "[", "WMOLocations", "]"}], ",", " ", 
          RowBox[{"ToExpression", "/@", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
             RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], 
            "}"}]}], ",", " ", "50"}], "]"}], "]"}], "]"}], ",", "\n", 
      RowBox[{"Mean", "[", 
       RowBox[{"GeoDistanceList", "[", 
        RowBox[{"GeoNearest", "[", 
         RowBox[{
          RowBox[{"Normal", "[", "WMOLocations", "]"}], ",", " ", 
          RowBox[{"ToExpression", "/@", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
             RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], 
            "}"}]}], ",", " ", "100"}], "]"}], "]"}], "]"}], ",", "\n", 
      RowBox[{"Mean", "[", 
       RowBox[{"GeoDistanceList", "[", 
        RowBox[{"GeoNearest", "[", 
         RowBox[{
          RowBox[{"Normal", "[", "WMOLocations", "]"}], ",", " ", 
          RowBox[{"ToExpression", "/@", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
             RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], 
            "}"}]}], ",", " ", "200"}], "]"}], "]"}], "]"}]}], "}"}], 
    "\t"}]}]}]], "Code",
