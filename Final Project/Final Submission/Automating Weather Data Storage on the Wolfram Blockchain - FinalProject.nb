      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"#Country", "===", "\"\<Mexico\>\""}], "&"}], "]"}], ",", 
      " ", "\"\<Position\>\""}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ptsMX", "=", 
   RowBox[{"RandomGeoPosition", "[", 
    RowBox[{
     TemplateBox[{"\"Mexico\"",RowBox[{"Entity", "[", 
         RowBox[{"\"Country\"", ",", "\"Mexico\""}], "]"}],
       "\"Entity[\\\"Country\\\", \\\"Mexico\\\"]\"","\"country\""},
      "Entity"], ",", "200"}], "]"}]}], ";"}], "\n", 
 RowBox[{"GeoGraphics", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Red", ",", 
       RowBox[{"Point", "/@", "WMOLocationsMX"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"Black", ",", 
       RowBox[{"Point", "[", "ptsMX", "]"}]}], "}"}]}], "}"}], ",", 
