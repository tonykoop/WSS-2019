Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Chart", " ", "the", " ", "weather", " ", 
    RowBox[{"station", "'"}], "s", " ", "Wind", " ", "Speed"}], "*)"}], "\n", 
  
  RowBox[{
   RowBox[{
    RowBox[{"windSpeed", "=", 
     RowBox[{
      RowBox[{"data", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"1", ";;", "All"}], ",", "2", ",", "1", ",", "3", ",", "2"}],
         "]"}], "]"}], "//", "Normal"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"myWindTimeSeries", "=", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"times", ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"MapAt", "[", 
            RowBox[{"ToExpression", ",", "#", ",", "1"}], "]"}], "&"}], "/@", 
          "windSpeed"}]}], "}"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"wmoWindTimeSeries", "=", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"times", ",", " ", 
         RowBox[{"WindSpeedData", "[", 
          RowBox[{"\"\<KBED\>\"", ",", " ", "times"}], "]"}]}], "}"}], "]"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"myWindTimeSeries", ",", " ", "wmoWindTimeSeries"}], "}"}], ",",
      "\n", "\t", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<Personal Weather Station\>\"", ",", 
        "\"\<Nearest ICAO Station\>\""}], "}"}]}]}], "]"}]}]}]], "Code",
