Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Collect", " ", "recent", " ", "Blockchain", " ", "sumbissions", " ", 
    "from", " ", "the", " ", "weather", " ", "station", " ", "and", " ", 
    "chart", " ", "the", " ", "temperature", " ", "over", " ", "time"}], 
   "*)"}], "  ", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Databin", "[", 
     RowBox[{"\"\<EM6FHeXi\>\"", ",", " ", "All"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"recentHashes", "=", 
     RowBox[{
      RowBox[{"Normal", "[", 
       RowBox[{"Dataset", "[", 
        RowBox[{"Databin", "[", 
         RowBox[{"\"\<EM6FHeXi\>\"", ",", " ", 
          RowBox[{"-", "24"}]}], "]"}], "]"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1", ",", 
        RowBox[{"-", "1"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Dataset", "[", 
      RowBox[{"BlockchainGet", "[", "recentHashes", "]"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"times", "=", 
     RowBox[{
      RowBox[{"data", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"1", ";;", "All"}], ",", "2", ",", "2"}], "]"}], "]"}], "//",
       "Normal"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"temps", "=", 
     RowBox[{
      RowBox[{"data", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"1", ";;", "All"}], ",", "2", ",", "1", ",", "1", ",", "2"}],
         "]"}], "]"}], "//", "Normal"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"myTempsTimeSeries", "=", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"times", ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"MapAt", "[", 
            RowBox[{"ToExpression", ",", "#", ",", "1"}], "]"}], "&"}], "/@", 
          "temps"}]}], "}"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"wmoTempsTimeSeries", "=", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"times", ",", " ", 
         RowBox[{"AirTemperatureData", "[", 
          RowBox[{"\"\<KBED\>\"", ",", " ", "times"}], "]"}]}], "}"}], "]"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"myTempsTimeSeries", ",", "wmoTempsTimeSeries"}], "}"}], ",", 
     " ", "\n", "\t", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<Personal Weather Station\>\"", ",", 
        "\"\<Nearest ICAO Station\>\""}], "}"}]}]}], "]"}]}]}]], "Code",
 CellChangeTimes->{{3.7711512358562727`*^9, 3.771151261943162*^9}, {
