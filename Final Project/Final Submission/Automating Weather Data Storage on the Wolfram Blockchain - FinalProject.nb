Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Send", " ", "a", " ", "login", " ", "request", " ", "with", " ", 
    "username", " ", "and", " ", "password", " ", "to", " ", "get", " ", "a", 
    " ", "session", " ", "token", " ", "and", " ", "account", " ", "ID"}], 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"loginData", "=", 
     RowBox[{"URLExecute", "[", 
      RowBox[{
       RowBox[{"HTTPRequest", "[", 
        RowBox[{"\[LeftAssociation]", "\n", 
         RowBox[{
          RowBox[{"Method", "\[Rule]", "\"\<POST\>\""}], ",", "\n", 
          RowBox[{"\"\<Scheme\>\"", "\[Rule]", "\"\<https\>\""}], ",", "\n", 
          RowBox[{
          "\"\<Domain\>\"", "\[Rule]", "\"\<marapi.myacurite.com\>\""}], ",", 
          "\n", 
          RowBox[{"\"\<Path\>\"", "\[Rule]", "\"\</users/login\>\""}], ",", 
          "\n", 
          RowBox[{
          "\"\<ContentType\>\"", "\[Rule]", "\"\<application/json\>\""}], ",",
           "\n", 
          RowBox[{"\"\<Body\>\"", "\[Rule]", 
           RowBox[{"ExportString", "[", 
            RowBox[{
             RowBox[{"<|", "\n", "\n", 
              RowBox[{
               RowBox[{
               "\"\<email\>\"", "\[Rule]", "\"\<wrfcoin@gmx.com\>\""}], ",", 
               "\n", 
               RowBox[{"\"\<password\>\"", "\[Rule]", "\"\<h5h3f**kD\>\""}], 
               ",", "\n", "\n", 
               RowBox[{"\"\<remember\>\"", "\[Rule]", "\"\<True\>\""}]}], 
              "\n", "|>"}], ",", "\"\<RawJSON\>\""}], "]"}]}]}], 
         "\[RightAssociation]"}], "]"}], ",", "\"\<RawJSON\>\""}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Find", " ", "the", " ", "ID", " ", "of", " ", "the", " ", "particular", 
     " ", "weather", " ", "station", " ", "in", " ", "question"}], "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{"hubsData", "=", 
     RowBox[{"URLExecute", "[", 
      RowBox[{
       RowBox[{"HTTPRequest", "[", 
        RowBox[{"<|", "\n", "   ", 
         RowBox[{
          RowBox[{"Method", " ", "\[Rule]", " ", "\"\<GET\>\""}], ",", "\n", 
          "   ", 
          RowBox[{"\"\<Scheme\>\"", " ", "\[Rule]", " ", "\"\<https\>\""}], 
          ",", "\n", "   ", 
          RowBox[{"\"\<Domain\>\"", " ", "\[Rule]", " ", 
           RowBox[{"\"\<marapi.myacurite.com/accounts/\>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"loginData", "[", 
              RowBox[{"[", 
               RowBox[{
               "\"\<user\>\"", ",", "\"\<account_users\>\"", ",", "1", ",", 
                "\"\<account_id\>\""}], "]"}], "]"}], "]"}], "<>", 
            "\"\</dashboard/hubs\>\""}]}], ",", "\n", "   ", 
          RowBox[{
          "\"\<ContentType\>\"", "\[Rule]", "\"\<application/json\>\""}], ",",
           "\n", "   ", 
          RowBox[{"\"\<Headers\>\"", " ", "\[Rule]", " ", 
           RowBox[{"{", 
            RowBox[{"\"\<x-one-vue-token\>\"", " ", "\[Rule]", " ", 
             RowBox[{"loginData", "[", "\"\<token_id\>\"", "]"}]}], "}"}]}]}],
          "|>"}], "]"}], ",", "\"\<RawJSON\>\""}], "]"}]}], ";"}], "\n", " ", 
   
   RowBox[{
    RowBox[{"myhubid", "=", 
     RowBox[{"hubsData", "[", 
      RowBox[{"[", 
       RowBox[{"\"\<account_hubs\>\"", ",", "1", ",", "\"\<id\>\""}], "]"}], 
      "]"}]}], ";"}], "\n", " ", "\n", " ", 
   RowBox[{"(*", 
    RowBox[{
    "Otain", " ", "the", " ", "current", " ", "data", " ", "feed", " ", 
     "from", " ", "the", " ", "particular", " ", "weather", " ", "station"}], 
    "*)"}], "\n", " ", 
   RowBox[{
    RowBox[{"weatherfeed", "=", 
     RowBox[{"URLExecute", "[", 
      RowBox[{
       RowBox[{"HTTPRequest", "[", 
        RowBox[{"<|", "\n", "   ", 
         RowBox[{
          RowBox[{"Method", " ", "\[Rule]", " ", "\"\<GET\>\""}], ",", "\n", 
          "   ", 
          RowBox[{"\"\<Scheme\>\"", " ", "\[Rule]", " ", "\"\<https\>\""}], 
          ",", "\n", "   ", 
          RowBox[{"\"\<Domain\>\"", " ", "\[Rule]", " ", 
           RowBox[{"\"\<marapi.myacurite.com/accounts/\>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"loginData", "[", 
              RowBox[{"[", 
               RowBox[{
               "\"\<user\>\"", ",", "\"\<account_users\>\"", ",", "1", ",", 
                "\"\<account_id\>\""}], "]"}], "]"}], "]"}], "<>", 
            "\"\</dashboard/hubs/\>\"", "<>", 
            RowBox[{"ToString", "[", "myhubid", "]"}]}]}], ",", "\n", "   ", 
          RowBox[{
          "\"\<ContentType\>\"", "\[Rule]", "\"\<application/json\>\""}], ",",
           "\n", "   ", 
          RowBox[{"\"\<Headers\>\"", " ", "\[Rule]", " ", 
           RowBox[{"{", 
            RowBox[{"\"\<x-one-vue-token\>\"", " ", "\[Rule]", " ", 
             RowBox[{"loginData", "[", "\"\<token_id\>\"", "]"}]}], "}"}]}]}],
          "|>"}], "]"}], ",", "\"\<RawJSON\>\""}], "]"}]}], ";"}], "\n", 
   "   ", "\n", "   ", 
   RowBox[{"(*", 
    RowBox[{"Organize", " ", 
     RowBox[{"data", ".", " ", "Consider"}], " ", "cases", " ", "with", " ", 
     "different", " ", "units"}], "*)"}], "\n", "   ", 
   RowBox[{
    RowBox[{"deviceRawData", "=", 
     RowBox[{"weatherfeed", "[", 
      RowBox[{"[", 
       RowBox[{"\"\<devices\>\"", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   "   ", 
   RowBox[{
    RowBox[{"sensorRawData", "=", 
     RowBox[{"AssociationThread", "[", 
      RowBox[{
       RowBox[{"deviceRawData", "[", 
        RowBox[{"[", 
         RowBox[{"\"\<sensors\>\"", ",", "All", ",", "\"\<sensor_name\>\""}], 
         "]"}], "]"}], "\[Rule]", 
       RowBox[{"deviceRawData", "[", 
        RowBox[{"[", "\"\<sensors\>\"", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
   "   ", 
   RowBox[{
    RowBox[{"sensorUnits", "=", 
     RowBox[{"<|", "\n", "   ", 
      RowBox[{
       RowBox[{"\"\<Temperature\>\"", "\[Rule]", 
        RowBox[{"Switch", "[", 
         RowBox[{
          RowBox[{"sensorRawData", "[", 
           RowBox[{"\"\<Temperature\>\"", ",", "\"\<chart_unit\>\""}], "]"}], 
          ",", "\"\<F\>\"", ",", "\"\<DegreesFahrenheit\>\"", ",", 
          "\"\<C\>\"", ",", "\"\<DegreesCelsius\>\""}], "]"}]}], ",", "\n", 
       "   ", 
       RowBox[{"\"\<Pressure\>\"", "\[Rule]", 
        RowBox[{"Switch", "[", 
         RowBox[{
          RowBox[{"sensorRawData", "[", 
           RowBox[{"\"\<Pressure\>\"", ",", "\"\<chart_unit\>\""}], "]"}], 
          ",", "\"\<inHg\>\"", ",", "\"\<InchesOfMercury\>\"", ",", 
          "\"\<hPa\>\"", ",", "\"\<Hectopascals\>\""}], "]"}]}], ",", "\n", 
       "   ", 
       RowBox[{"\"\<Humidity\>\"", "\[Rule]", "\"\<Percent\>\""}], ",", "\n", 
       "   ", 
       RowBox[{"\"\<Wind Speed\>\"", "\[Rule]", 
        RowBox[{"Switch", "[", 
         RowBox[{
          RowBox[{"sensorRawData", "[", 
           RowBox[{"\"\<Wind Speed\>\"", ",", "\"\<chart_unit\>\""}], "]"}], 
          ",", "\"\<mph\>\"", ",", 
          RowBox[{"\"\<Miles\>\"", "/", "\"\<Hours\>\""}], ",", 
          "\"\<km/h\>\"", ",", 
          RowBox[{"\"\<Kilometers\>\"", "/", "\"\<Hours\>\""}], ",", 
          "\"\<kn\>\"", ",", "\"\<Knots\>\""}], "]"}]}], ",", "\n", "   ", 
       RowBox[{"\"\<Wind Direction\>\"", "\[Rule]", "\"\<Degrees\>\""}], ",", 
       "\n", "   ", 
       RowBox[{"\"\<Rainfall\>\"", "\[Rule]", 
        RowBox[{"Switch", "[", 
         RowBox[{
          RowBox[{"sensorRawData", "[", 
           RowBox[{"\"\<Rainfall\>\"", ",", "\"\<chart_unit\>\""}], "]"}], 
          ",", "\"\<in\>\"", ",", "\"\<Inches\>\"", ",", "\"\<mm\>\"", ",", 
          "\"\<Millimeters\>\""}], "]"}]}], ",", "\n", "   ", 
       RowBox[{"\"\<Dew Point\>\"", "\[Rule]", 
        RowBox[{"Switch", "[", 
         RowBox[{
          RowBox[{"sensorRawData", "[", 
           RowBox[{"\"\<Dew Point\>\"", ",", "\"\<chart_unit\>\""}], "]"}], 
          ",", "\"\<F\>\"", ",", "\"\<DegreesFahrenheit\>\"", ",", 
          "\"\<C\>\"", ",", "\"\<DegreesCelsius\>\""}], "]"}]}], ",", "\n", 
       "   ", 
       RowBox[{"\"\<Feels Like\>\"", "\[Rule]", 
        RowBox[{"Switch", "[", 
         RowBox[{
          RowBox[{"sensorRawData", "[", 
           RowBox[{"\"\<Feels Like\>\"", ",", "\"\<chart_unit\>\""}], "]"}], 
          ",", "\"\<F\>\"", ",", "\"\<DegreesFahrenheit\>\"", ",", 
          "\"\<C\>\"", ",", "\"\<DegreesCelsius\>\""}], "]"}]}], ",", "\n", 
       "   ", 
       RowBox[{"\"\<Wind Speed Average\>\"", "\[Rule]", 
        RowBox[{"Switch", "[", 
         RowBox[{
          RowBox[{"sensorRawData", "[", 
           RowBox[{"\"\<Wind Speed\>\"", ",", "\"\<chart_unit\>\""}], "]"}], 
          ",", "\"\<mph\>\"", ",", 
          RowBox[{"\"\<Miles\>\"", "/", "\"\<Hours\>\""}], ",", 
          "\"\<km/h\>\"", ",", 
          RowBox[{"\"\<Kilometers\>\"", "/", "\"\<Hours\>\""}], ",", 
          "\"\<kn\>\"", ",", "\"\<Knots\>\""}], "]"}]}]}], "|>"}]}], ";"}], 
   "\n", "\t", "\n", 
   RowBox[{
    RowBox[{"sensorData", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Sensor\>\"", "\[Rule]", 
          RowBox[{"#", "[", "\"\<sensor_name\>\"", "]"}]}], ",", 
         RowBox[{"\"\<Value\>\"", "\[Rule]", 
          RowBox[{"Quantity", "[", 
           RowBox[{
            RowBox[{"#", "[", "\"\<last_reading_value\>\"", "]"}], ",", 
            RowBox[{"sensorUnits", "[", 
             RowBox[{"#", "[", "\"\<sensor_name\>\"", "]"}], "]"}]}], 
           "]"}]}]}], "|>"}], "&"}], "/@", 
      RowBox[{"Values", "@", "sensorRawData"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Include", " ", "timestamp"}], ",", " ", "latitude", ",", " ", 
     "longitude", ",", " ", 
     RowBox[{
     "and", " ", "elevation", " ", "into", " ", "the", " ", "table"}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"isoStringWithTZToDateObject", "[", "string_String", "]"}], ":=", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"by", " ", "Jesse"}], " ", "*)"}], 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"stringParts", "=", 
         RowBox[{"StringSplit", "[", 
          RowBox[{"string", ",", 
           RowBox[{
           "RegularExpression", "[", 
            "\"\<(?=((\\\\+|-)\\\\d{2}:\\\\d{2})|Z$)\>\"", "]"}]}], "]"}]}], 
        ",", "tzpart", ",", "tzoffset", ",", "signedtzoffset"}], "}"}], ",", 
      "\n", 
      RowBox[{
       RowBox[{"Which", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "stringParts", "]"}], "===", "1"}], ",", 
         RowBox[{"signedtzoffset", "=", "Automatic"}], ",", 
         RowBox[{
          RowBox[{"ToUpperCase", "[", 
           RowBox[{"stringParts", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}], "===", "\"\<Z\>\""}], ",", 
         
         RowBox[{"signedtzoffset", "=", "0"}], ",", "True", ",", 
         RowBox[{
          RowBox[{"tzpart", "=", 
           RowBox[{"StringSplit", "[", 
            RowBox[{
             RowBox[{"stringParts", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", "\n", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
               "RegularExpression", "[", "\"\<(?<=\\\\+|-)\>\"", "]"}], ",", 
               "\"\<:\>\""}], "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"tzoffset", "=", 
           RowBox[{"NumberCompose", "[", 
            RowBox[{
             RowBox[{"FromDigits", "/@", 
              RowBox[{"Rest", "[", "tzpart", "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", 
               RowBox[{"1", "/", "60"}]}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"signedtzoffset", "=", 
           RowBox[{"N", "@", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"tzpart", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "===", "\"\<-\>\""}], ",", 
              RowBox[{"-", "tzoffset"}], ",", "tzoffset"}], "]"}]}]}], 
          ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"DateObject", "[", 
        RowBox[{
         RowBox[{"stringParts", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"TimeZone", "\[Rule]", "signedtzoffset"}]}], "]"}]}]}], 
     "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{"weatherEntry", "=", 
     RowBox[{"dataTable", "=", 
      RowBox[{"<|", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<Sensors\>\"", "\[Rule]", "sensorData"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<Timestamp\>\"", "\[Rule]", 
         RowBox[{"TimeZoneConvert", "[", 
          RowBox[{"isoStringWithTZToDateObject", "[", 
           RowBox[{"deviceRawData", "[", "\"\<last_check_in_at\>\"", "]"}], 
           "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Position\>\"", "\[Rule]", 
         RowBox[{"GeoPosition", "[", 
          RowBox[{"Append", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Interpreter", "[", "\"\<Real\>\"", "]"}], "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
               RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], 
              "}"}], "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"Quantity", "[", 
             RowBox[{
              RowBox[{"weatherfeed", "[", "\"\<elevation\>\"", "]"}], ",", 
              RowBox[{"Switch", "[", 
               RowBox[{
                RowBox[{"weatherfeed", "[", "\"\<elevation_unit\>\"", "]"}], 
                ",", "\"\<ft\>\"", ",", "\"\<Feet\>\"", ",", "\"\<m\>\"", 
                ",", "\"\<Meters\>\""}], "]"}]}], "]"}]}], "]"}], "]"}]}]}], 
       "|>"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"convertWeatherEntryToCompleteSet", "[", "weatherEntry_", "]"}], ":=",
     " ", 
    RowBox[{"Module", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "sensorData", ",", " ", "time", ",", " ", "geolocation", ",", " ", 
        RowBox[{"sensorIndex", " ", "=", " ", "1"}], ",", " ", 
        RowBox[{"timeIndex", " ", "=", " ", "2"}], ",", " ", 
        RowBox[{"positionIndex", " ", "=", " ", "3"}]}], "}"}], ",", "\t", 
      "\n", "\t", 
      RowBox[{
       RowBox[{"sensorData", " ", "=", " ", 
        RowBox[{"Values", " ", "/@", " ", 
         RowBox[{
          RowBox[{"Values", "[", "weatherEntry", "]"}], 
          "\[LeftDoubleBracket]", "sensorIndex", 
          "\[RightDoubleBracket]"}]}]}], ";", "\n", "\t", 
       RowBox[{"time", " ", "=", " ", 
        RowBox[{"\"\<Timestamp\>\"", " ", "\[Rule]", " ", 
         RowBox[{
          RowBox[{"Values", "[", "weatherEntry", "]"}], 
          "\[LeftDoubleBracket]", "timeIndex", "\[RightDoubleBracket]"}]}]}], 
       ";", "\n", "\t", 
       RowBox[{"geolocation", " ", "=", " ", 
        RowBox[{"\"\<Position\>\"", " ", "\[Rule]", " ", 
         RowBox[{
          RowBox[{"Values", "[", "weatherEntry", "]"}], 
          "\[LeftDoubleBracket]", "positionIndex", 
          "\[RightDoubleBracket]"}]}]}], ";", "\t", "\n", "\t", 
       RowBox[{"Association", " ", "@", " ", 
        RowBox[{"Flatten", " ", "@", " ", 
         RowBox[{"Join", "[", 
          RowBox[{"{", 
           RowBox[{"time", ",", " ", "geolocation", ",", " ", 
            RowBox[{"Rule", " ", "@@@", " ", "sensorData"}]}], "}"}], 
          "]"}]}]}]}]}], "]"}]}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Insert", " ", "the", " ", "weatherEntry", " ", "and", " ", "its", " ", 
     "hash", " ", "into", " ", "the", " ", "Wolfram", " ", "Blockchain", " ", 
     "and", " ", "a", " ", "Databin"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"previousHash", "=", 
     RowBox[{"Hash", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Normal", "[", 
         RowBox[{"Databin", "[", 
          RowBox[{"\"\<EM6FHeXi\>\"", ",", 
           RowBox[{"-", "1"}]}], "]"}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "2"}], "]"}], "]"}], ",", "\"\<SHA256\>\""}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"list", "=", 
     RowBox[{"{", 
      RowBox[{"previousHash", ",", " ", "weatherEntry"}], "}"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"trxID", "=", 
     RowBox[{"BlockchainPut", "[", "list", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"listDB", "=", 
     RowBox[{"{", 
      RowBox[{"previousHash", ",", " ", 
       RowBox[{"Hash", "[", 
        RowBox[{"weatherEntry", ",", "\"\<SHA256\>\""}], "]"}], ",", 
       "trxID"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"DatabinAdd", "[", 
     RowBox[{"\"\<EM6FHeXi\>\"", ",", "listDB"}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Check", " ", "that", " ", "the", " ", "entry", " ", "returned", " ", 
      "from", " ", "the", " ", "blockchain", " ", "computes", " ", "the", " ",
       "same", " ", "weatherHash"}], ",", " ", 
     RowBox[{
     "recall", " ", "last", " ", "ten", " ", "entries", " ", "into", " ", 
      "Databin"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Hash", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"BlockchainGet", "[", "trxID", "]"}], "\[LeftDoubleBracket]", 
       "2", "\[RightDoubleBracket]"}], ",", " ", "\"\<SHA256\>\""}], "]"}], "===", 
    RowBox[{"Hash", "[", 
     RowBox[{"weatherEntry", ",", " ", "\"\<SHA256\>\""}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"convertWeatherEntryToCompleteSet", "[", "weatherEntry", "]"}], "//",
     "Dataset"}], "\n"}]}]], "Code",
