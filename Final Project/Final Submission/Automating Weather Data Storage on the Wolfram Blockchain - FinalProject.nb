Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"WMOLocationsRA", "=", 
     RowBox[{"Values", "@", 
      RowBox[{
       RowBox[{
       "ResourceData", "[", "\"\<WMO Meteorological Stations\>\"", "]"}], "[", 
       RowBox[{
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"#Country", "===", "\"\<Russia\>\""}], "&"}], "]"}], ",", 
        " ", "\"\<Position\>\""}], "]"}]}]}], ";", "\n", 
    RowBox[{"ptsRA", "=", 
     RowBox[{"RandomGeoPosition", "[", 
      RowBox[{
       TemplateBox[{"\"Russia\"",RowBox[{"Entity", "[", 
           RowBox[{"\"Country\"", ",", "\"Russia\""}], "]"}],
         "\"Entity[\\\"Country\\\", \\\"Russia\\\"]\"","\"country\""},
        "Entity"], ",", "100"}], "]"}]}], ";", "\n", 
    RowBox[{
     RowBox[{
      RowBox[{"GeoGraphics", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Red", ",", 
            RowBox[{"Point", "/@", "WMOLocationsRA"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"Black", ",", 
            RowBox[{"Point", "[", "ptsRA", "]"}]}], "}"}]}], "}"}], ",", 
        RowBox[{"GeoRange", "\[Rule]", 
         TemplateBox[{"\"Russia\"",RowBox[{"Entity", "[", 
             RowBox[{"\"Country\"", ",", "\"Russia\""}], "]"}],
           "\"Entity[\\\"Country\\\", \\\"Russia\\\"]\"","\"country\""},
          "Entity"]}]}], "]"}], "\n", "nearestDistancesRA"}], " ", "=", " ", 
     RowBox[{"GeoNearest", "[", 
      RowBox[{
       RowBox[{"WMOLocationsRA", "//", "Normal"}], ",", 
       RowBox[{"ptsRA", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", "\n", 
    RowBox[{
     RowBox[{
     "Print", "[", "\"\<Average Distance to nearest WMO Station\>\"", "]"}], 
     "\n", 
     RowBox[{"Mean", "[", 
      RowBox[{"GeoDistance", "@@@", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"nearestDistancesRA", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1", ",", "1"}], "]"}], "]"}], ",", 
          RowBox[{"ptsRA", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "}"}], "]"}]}], "]"}], "\n", 
     RowBox[{"Print", "[", "\"\<WMO Stations per Square Mile\>\"", "]"}], 
     "\n", 
     RowBox[{"ScientificForm", "[", 
      RowBox[{
       RowBox[{"Length", "[", "WMOLocationsRA", "]"}], "/", 
       RowBox[{"EntityValue", "[", 
        RowBox[{
         TemplateBox[{"\"Russia\"",RowBox[{"Entity", "[", 
             RowBox[{"\"Country\"", ",", "\"Russia\""}], "]"}],
           "\"Entity[\\\"Country\\\", \\\"Russia\\\"]\"","\"country\""},
          "Entity"], ",", "\"\<Area\>\""}], "]"}]}], "]"}]}]}], "*)"}], "\n", 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"WMOLocationsAL", "=", 
