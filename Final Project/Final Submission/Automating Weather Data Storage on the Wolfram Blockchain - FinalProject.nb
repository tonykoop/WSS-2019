       "\"Entity[\\\"Country\\\", \\\"UnitedStates\\\"]\"","\"country\""},
      "Entity"], ",", "200"}], "]"}]}], ";"}], "\n", 
 RowBox[{"GeoGraphics", "[", 
  RowBox[{
   RowBox[{"{", 
