Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"isoStringWithTZToDateObject", "[", "string_String", "]"}], ":=", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"by", " ", "Jesse"}], " ", "*)"}], 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"stringParts", "=", 
         RowBox[{"StringSplit", "[", 
          RowBox[{"string", ",", 
           RowBox[{
           "RegularExpression", "[", 
            "\"\<(?=((\\\\+|-)\\\\d{2}:\\\\d{2})|Z$)\>\"", "]"}]}], "]"}]}], 
        ",", "tzpart", ",", "tzoffset", ",", "signedtzoffset"}], "}"}], ",", 
      RowBox[{
       RowBox[{"Which", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "stringParts", "]"}], "===", "1"}], ",", 
         RowBox[{"signedtzoffset", "=", "Automatic"}], ",", 
         RowBox[{
          RowBox[{"ToUpperCase", "[", 
           RowBox[{"stringParts", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}], "===", "\"\<Z\>\""}], ",", 
         
         RowBox[{"signedtzoffset", "=", "0"}], ",", "True", ",", 
         RowBox[{
          RowBox[{"tzpart", "=", 
           RowBox[{"StringSplit", "[", 
            RowBox[{
             RowBox[{"stringParts", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
               "RegularExpression", "[", "\"\<(?<=\\\\+|-)\>\"", "]"}], ",", 
               "\"\<:\>\""}], "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"tzoffset", "=", 
           RowBox[{"NumberCompose", "[", 
            RowBox[{
             RowBox[{"FromDigits", "/@", 
              RowBox[{"Rest", "[", "tzpart", "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", 
               RowBox[{"1", "/", "60"}]}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"signedtzoffset", "=", 
           RowBox[{"N", "@", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"tzpart", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "===", "\"\<-\>\""}], ",", 
              RowBox[{"-", "tzoffset"}], ",", "tzoffset"}], "]"}]}]}], 
          ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"DateObject", "[", 
        RowBox[{
         RowBox[{"stringParts", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"TimeZone", "\[Rule]", "signedtzoffset"}]}], "]"}]}]}], 
     "]"}]}], ";"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"frequency", "=", 
     TemplateBox[{"15","\"min\"","minutes","\"Minutes\""},
      "Quantity"]}], ";"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"frequency", "=", 
   TemplateBox[{"60","\"min\"","minutes","\"Minutes\""},
    "Quantity"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"stask", "=", 
   RowBox[{"ScheduledTask", "[", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
        "loginData", ",", "\[IndentingNewLine]", "mytoken", ",", 
         "\[IndentingNewLine]", "myaccountid", ",", "\[IndentingNewLine]", 
         "hubsData", ",", "\[IndentingNewLine]", "myhubid", ",", 
         "\[IndentingNewLine]", "weatherfeed", ",", "\[IndentingNewLine]", 
         "deviceRawData", ",", "\[IndentingNewLine]", "sensorRawData", ",", 
         "\[IndentingNewLine]", "sensorUnits", ",", "\[IndentingNewLine]", 
         "sensorData", ",", "\[IndentingNewLine]", "weatherEntry", ",", 
         "\[IndentingNewLine]", "weatherHash", ",", "\[IndentingNewLine]", 
         "list", ",", "\[IndentingNewLine]", "trxID"}], "\[IndentingNewLine]",
         "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Send", " ", "a", " ", "login", " ", "request", " ", "with", " ", 
         "username", " ", "and", " ", "password", " ", "to", " ", "get", " ", 
         "a", " ", "session", " ", "token", " ", "and", " ", "account", " ", 
         "ID"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"loginData", "=", 
         RowBox[{"URLExecute", "[", 
          RowBox[{
           RowBox[{"HTTPRequest", "[", 
            RowBox[{"\[LeftAssociation]", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Method", "\[Rule]", "\"\<POST\>\""}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<Scheme\>\"", "\[Rule]", "\"\<https\>\""}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{
              "\"\<Domain\>\"", "\[Rule]", "\"\<marapi.myacurite.com\>\""}], 
              ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<Path\>\"", "\[Rule]", "\"\</users/login\>\""}], 
              ",", "\[IndentingNewLine]", 
              RowBox[{
              "\"\<ContentType\>\"", "\[Rule]", "\"\<application/json\>\""}], 
              ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<Body\>\"", "\[Rule]", 
               RowBox[{"ExportString", "[", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"<|", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{
                   "\"\<email\>\"", "\[Rule]", "\"\<wrfcoin@gmx.com\>\""}], 
                   ",", "\[IndentingNewLine]", 
                   RowBox[{
                   "\"\<password\>\"", "\[Rule]", "\"\<h5h3f**kD\>\""}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"\"\<remember\>\"", "\[Rule]", "\"\<True\>\""}]}], 
                  "\[IndentingNewLine]", "|>"}], ",", "\[IndentingNewLine]", 
                 "\"\<RawJSON\>\""}], "]"}]}]}], "\[IndentingNewLine]", 
             "\[RightAssociation]"}], "]"}], ",", "\"\<RawJSON\>\""}], 
          "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"mytoken", "=", 
         RowBox[{"loginData", "[", "\"\<token_id\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"myaccountid", "=", 
         RowBox[{"loginData", "[", 
          RowBox[{"[", 
           RowBox[{
           "\"\<user\>\"", ",", "\"\<account_users\>\"", ",", "1", ",", 
            "\"\<account_id\>\""}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Find", " ", "the", " ", "ID", " ", "of", " ", "the", " ", 
          "particular", " ", "weather", " ", "station", " ", "in", " ", 
          "question"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"hubsData", "=", 
         RowBox[{"URLExecute", "[", 
          RowBox[{
           RowBox[{"HTTPRequest", "[", 
            RowBox[{"<|", "\[IndentingNewLine]", " ", 
             RowBox[{
              RowBox[{"Method", " ", "\[Rule]", " ", "\"\<GET\>\""}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{
              "\"\<Scheme\>\"", " ", "\[Rule]", " ", "\"\<https\>\""}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<Domain\>\"", " ", "\[Rule]", " ", 
               RowBox[{"\"\<marapi.myacurite.com/accounts/\>\"", "<>", 
                RowBox[{"ToString", "[", "myaccountid", "]"}], "<>", 
                "\"\</dashboard/hubs\>\""}]}], ",", 
              RowBox[{
              "\"\<ContentType\>\"", "\[Rule]", "\"\<application/json\>\""}], 
              ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<Headers\>\"", " ", "\[Rule]", " ", 
               RowBox[{"{", 
                RowBox[{
                "\"\<x-one-vue-token\>\"", " ", "\[Rule]", " ", "mytoken"}], 
                "}"}]}]}], "\[IndentingNewLine]", "|>"}], "]"}], ",", 
           "\"\<RawJSON\>\""}], "]"}]}], ";", "\[IndentingNewLine]", " ", 
        RowBox[{"myhubid", "=", 
         RowBox[{"hubsData", "[", 
          RowBox[{"[", 
           RowBox[{"\"\<account_hubs\>\"", ",", "1", ",", "\"\<id\>\""}], 
           "]"}], "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        
        RowBox[{"(*", 
         RowBox[{
         "Obtain", " ", "the", " ", "current", " ", "data", " ", "feed", " ", 
          "from", " ", "the", " ", "particular", " ", "weather", " ", 
          "station"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"weatherfeed", "=", 
         RowBox[{"URLExecute", "[", 
          RowBox[{
           RowBox[{"HTTPRequest", "[", 
            RowBox[{"<|", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Method", " ", "\[Rule]", " ", "\"\<GET\>\""}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{
              "\"\<Scheme\>\"", " ", "\[Rule]", " ", "\"\<https\>\""}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<Domain\>\"", " ", "\[Rule]", " ", 
               RowBox[{"\"\<marapi.myacurite.com/accounts/\>\"", "<>", 
                RowBox[{"ToString", "[", "myaccountid", "]"}], "<>", 
                "\"\</dashboard/hubs/\>\"", "<>", 
                RowBox[{"ToString", "[", "myhubid", "]"}]}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{
              "\"\<ContentType\>\"", "\[Rule]", "\"\<application/json\>\""}], 
              ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<Headers\>\"", " ", "\[Rule]", " ", 
               RowBox[{"{", 
                RowBox[{
                "\"\<x-one-vue-token\>\"", " ", "\[Rule]", " ", "mytoken"}], 
                "}"}]}]}], "\[IndentingNewLine]", "|>"}], "]"}], ",", 
           "\"\<RawJSON\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Organize", " ", 
          RowBox[{"data", ".", " ", "Consider"}], " ", "cases", " ", "with", 
          " ", "different", " ", "units"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"deviceRawData", "=", 
         RowBox[{"weatherfeed", "[", 
          RowBox[{"[", 
           RowBox[{"\"\<devices\>\"", ",", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"sensorRawData", "=", 
         RowBox[{"AssociationThread", "[", 
          RowBox[{
           RowBox[{"deviceRawData", "[", 
            RowBox[{"[", 
             RowBox[{
             "\"\<sensors\>\"", ",", "All", ",", "\"\<sensor_name\>\""}], 
             "]"}], "]"}], "\[Rule]", 
           RowBox[{"deviceRawData", "[", 
            RowBox[{"[", "\"\<sensors\>\"", "]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"sensorUnits", "=", 
         RowBox[{"<|", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"\"\<Temperature\>\"", "\[Rule]", 
            RowBox[{"Switch", "[", 
             RowBox[{
              RowBox[{"sensorRawData", "[", 
               RowBox[{"\"\<Temperature\>\"", ",", "\"\<chart_unit\>\""}], 
               "]"}], ",", "\"\<F\>\"", ",", "\"\<DegreesFahrenheit\>\"", 
              ",", "\"\<C\>\"", ",", "\"\<DegreesCelsius\>\""}], "]"}]}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"\"\<Pressure\>\"", "\[Rule]", 
            RowBox[{"Switch", "[", 
             RowBox[{
              RowBox[{"sensorRawData", "[", 
               RowBox[{"\"\<Pressure\>\"", ",", "\"\<chart_unit\>\""}], "]"}],
               ",", "\"\<inHg\>\"", ",", "\"\<InchesOfMercury\>\"", ",", 
              "\"\<hPa\>\"", ",", "\"\<Hectopascals\>\""}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"\"\<Humidity\>\"", "\[Rule]", "\"\<Percent\>\""}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"\"\<Wind Speed\>\"", "\[Rule]", 
            RowBox[{"Switch", "[", 
             RowBox[{
              RowBox[{"sensorRawData", "[", 
               RowBox[{"\"\<Wind Speed\>\"", ",", "\"\<chart_unit\>\""}], 
               "]"}], ",", "\"\<mph\>\"", ",", 
              RowBox[{"\"\<Miles\>\"", "/", "\"\<Hours\>\""}], ",", 
              "\"\<km/h\>\"", ",", 
              RowBox[{"\"\<Kilometers\>\"", "/", "\"\<Hours\>\""}], ",", 
              "\"\<kn\>\"", ",", "\"\<Knots\>\""}], "]"}]}], ",", 
           RowBox[{"\"\<Wind Direction\>\"", "\[Rule]", "\"\<Degrees\>\""}], 
           ",", "\[IndentingNewLine]", 
           RowBox[{"\"\<Rainfall\>\"", "\[Rule]", 
            RowBox[{"Switch", "[", 
             RowBox[{
              RowBox[{"sensorRawData", "[", 
               RowBox[{"\"\<Rainfall\>\"", ",", "\"\<chart_unit\>\""}], "]"}],
               ",", "\"\<in\>\"", ",", "\"\<Inches\>\"", ",", "\"\<mm\>\"", 
              ",", "\"\<Millimeters\>\""}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"\"\<Dew Point\>\"", "\[Rule]", 
            RowBox[{"Switch", "[", 
             RowBox[{
              RowBox[{"sensorRawData", "[", 
               RowBox[{"\"\<Dew Point\>\"", ",", "\"\<chart_unit\>\""}], 
               "]"}], ",", "\"\<F\>\"", ",", "\"\<DegreesFahrenheit\>\"", 
              ",", "\"\<C\>\"", ",", "\"\<DegreesCelsius\>\""}], "]"}]}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"\"\<Feels Like\>\"", "\[Rule]", 
            RowBox[{"Switch", "[", 
             RowBox[{
              RowBox[{"sensorRawData", "[", 
               RowBox[{"\"\<Feels Like\>\"", ",", "\"\<chart_unit\>\""}], 
               "]"}], ",", "\"\<F\>\"", ",", "\"\<DegreesFahrenheit\>\"", 
              ",", "\"\<C\>\"", ",", "\"\<DegreesCelsius\>\""}], "]"}]}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"\"\<Wind Speed Average\>\"", "\[Rule]", 
            RowBox[{"Switch", "[", 
             RowBox[{
              RowBox[{"sensorRawData", "[", 
               RowBox[{"\"\<Wind Speed\>\"", ",", "\"\<chart_unit\>\""}], 
               "]"}], ",", "\"\<mph\>\"", ",", 
              RowBox[{"\"\<Miles\>\"", "/", "\"\<Hours\>\""}], ",", 
              "\"\<km/h\>\"", ",", 
              RowBox[{"\"\<Kilometers\>\"", "/", "\"\<Hours\>\""}], ",", 
              "\"\<kn\>\"", ",", "\"\<Knots\>\""}], "]"}]}]}], 
          "\[IndentingNewLine]", "|>"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"sensorData", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<Sensor\>\"", "\[Rule]", 
              RowBox[{"#", "[", "\"\<sensor_name\>\"", "]"}]}], ",", 
             RowBox[{"\"\<Value\>\"", "\[Rule]", 
              RowBox[{"Quantity", "[", 
               RowBox[{
                RowBox[{"#", "[", "\"\<last_reading_value\>\"", "]"}], ",", 
                RowBox[{"sensorUnits", "[", 
                 RowBox[{"#", "[", "\"\<sensor_name\>\"", "]"}], "]"}]}], 
               "]"}]}]}], "|>"}], "&"}], "/@", 
          RowBox[{"Values", "@", "sensorRawData"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Include", " ", "timestamp"}], ",", " ", "latitude", ",", 
          " ", "longitude", ",", " ", 
          RowBox[{
          "and", " ", "elevation", " ", "into", " ", "the", " ", "table"}]}], 
         "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"weatherEntry", "=", 
         RowBox[{"dataTable", "=", 
          RowBox[{"<|", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\"\<Sensors\>\"", "\[Rule]", "sensorData"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<ReadingTimestamp\>\"", "\[Rule]", 
             RowBox[{"TimeZoneConvert", "[", 
              RowBox[{"isoStringWithTZToDateObject", "[", 
               RowBox[{
               "deviceRawData", "[", "\"\<last_check_in_at\>\"", "]"}], "]"}],
               "]"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"\"\<SubmisisonTimestamp\>\"", "\[Rule]", "Now"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Position\>\"", "\[Rule]", 
             RowBox[{"GeoPosition", "[", 
              RowBox[{"Append", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"Interpreter", "[", "\"\<Real\>\"", "]"}], "[", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"weatherfeed", "[", "\"\<latitude\>\"", "]"}], ",", 
                   RowBox[{"weatherfeed", "[", "\"\<longitude\>\"", "]"}]}], 
                  "}"}], "]"}], ",", "\[IndentingNewLine]", 
                RowBox[{"Quantity", "[", 
                 RowBox[{
                  RowBox[{"weatherfeed", "[", "\"\<elevation\>\"", "]"}], ",", 
                  RowBox[{"Switch", "[", 
                   RowBox[{
                    RowBox[{
                    "weatherfeed", "[", "\"\<elevation_unit\>\"", "]"}], ",", 
                    "\"\<ft\>\"", ",", "\"\<Feet\>\"", ",", "\"\<m\>\"", ",", 
                    "\"\<Meters\>\""}], "]"}]}], "]"}]}], "]"}], "]"}]}]}], 
           "\[IndentingNewLine]", "|>"}]}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Insert", " ", "the", " ", "weatherEntry", " ", "and", " ", "its", 
          " ", "hash", " ", "into", " ", "the", " ", "Wolfram", " ", 
          "Blockchain", " ", "and", " ", "a", " ", "Databin"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"previousHash", "=", 
         RowBox[{"Hash", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Normal", "[", 
             RowBox[{"Databin", "[", 
              RowBox[{"\"\<EM6FHeXi\>\"", ",", 
               RowBox[{"-", "1"}]}], "]"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "2"}], "]"}], "]"}], ",", "\"\<SHA256\>\""}], 
          "]"}]}], ";", "\n", 
        RowBox[{"list", "=", 
         RowBox[{"{", 
          RowBox[{"previousHash", ",", " ", "weatherEntry"}], "}"}]}], ";", 
        "\n", 
        RowBox[{"trxID", "=", 
         RowBox[{"BlockchainPut", "[", "list", "]"}]}], ";", "\n", 
        RowBox[{"listDB", "=", 
         RowBox[{"{", 
          RowBox[{"previousHash", ",", " ", 
           RowBox[{"Hash", "[", 
            RowBox[{"weatherEntry", ",", "\"\<SHA256\>\""}], "]"}], ",", 
           "trxID"}], "}"}]}], ";", "\n", 
        RowBox[{"DatabinAdd", "[", 
         RowBox[{"\"\<EM6FHeXi\>\"", ",", "listDB"}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ",", "frequency"}], "]"}]}], ";"}], "\n", 

 RowBox[{
  RowBox[{
   RowBox[{"task", "=", 
    RowBox[{"SessionSubmit", "[", 
     RowBox[{"Evaluate", "@", "stask"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"obj", "=", 
  RowBox[{"CloudDeploy", "[", 
   RowBox[{"stask", ",", "\"\<BlockchainWeatherUpdate\>\""}], 
   "]"}]}]}], "Code",
 CellChangeTimes->{{3.771700679381381*^9, 3.77170070448557*^9}, {
