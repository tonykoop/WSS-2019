Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Chart", " ", "the", " ", "weather", " ", 
    RowBox[{"station", "'"}], "s", " ", "Humidity"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"humidity", "=", 
     RowBox[{
      RowBox[{"data", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"1", ";;", "All"}], ",", "2", ",", "1", ",", "2", ",", "2"}],
         "]"}], "]"}], "//", "Normal"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"myHumidityTimeSeries", "=", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"times", ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"MapAt", "[", 
            RowBox[{"ToExpression", ",", "#", ",", "1"}], "]"}], "&"}], "/@", 
          "humidity"}]}], "}"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"wmoHumidityTimeSeries", "=", 
     RowBox[{
      RowBox[{"WeatherData", "[", 
       RowBox[{"\"\<KBED\>\"", ",", "\"\<Humidity\>\"", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Now", "-", 
           TemplateBox[{"1","\"day\"","day","\"Days\""},
            "Quantity"]}], ",", " ", "Now"}], "}"}]}], "]"}], "*", "100"}]}], 
    ";"}], "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"myHumidityTimeSeries", ",", "wmoHumidityTimeSeries"}], "}"}], 
     ",", "\n", "\t", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<Personal Weather Station\>\"", ",", 
        "\"\<Nearest ICAO Station\>\""}], "}"}]}]}], "]"}]}]}]], "Code",
