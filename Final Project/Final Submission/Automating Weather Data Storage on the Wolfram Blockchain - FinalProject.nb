Cell[BoxData[{
 RowBox[{
  RowBox[{"WMOStations", "=", 
   RowBox[{
   "ResourceObject", "[", "\"\<WMO Meteorological Stations\>\"", "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"WMOLocations", "=", 
   RowBox[{"Values", "@", 
    RowBox[{
     RowBox[{
     "ResourceData", "[", "\"\<WMO Meteorological Stations\>\"", "]"}], "[", 
     RowBox[{
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"#Country", "===", "\"\<United States\>\""}], "&"}], "]"}], 
      ",", " ", "\"\<Position\>\""}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pts", "=", 
