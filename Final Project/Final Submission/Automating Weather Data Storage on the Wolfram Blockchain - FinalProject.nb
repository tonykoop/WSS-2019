    TemplateBox[{"\"Mexico\"",RowBox[{"Entity", "[", 
        RowBox[{"\"Country\"", ",", "\"Mexico\""}], "]"}],
      "\"Entity[\\\"Country\\\", \\\"Mexico\\\"]\"","\"country\""},
     "Entity"]}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"nearestDistancesMX", " ", "=", " ", 
   RowBox[{"GeoNearest", "[", 
    RowBox[{
     RowBox[{"WMOLocationsMX", "//", "Normal"}], ",", 
     RowBox[{"ptsMX", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Print", "[", "\"\<Average Distance to nearest WMO Station\>\"", 
  "]"}], "\n", 
