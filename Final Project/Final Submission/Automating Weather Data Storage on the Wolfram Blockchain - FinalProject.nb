  RowBox[{"GeoDistance", "@@@", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"nearestDistancesMX", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1", ",", "1"}], "]"}], "]"}], ",", 
      RowBox[{"ptsMX", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], "}"}], "]"}]}], "]"}], "\n", 
 RowBox[{"Print", "[", "\"\<WMO Stations per Square Mile\>\"", "]"}], "\n", 
